{
  "name": "@qooma/auth-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Auth & Identity service untuk ekosistem Qooma (microservices). Owns: users (semua role), sessions, hotels (tenant), tiers (catalog), RBAC, super_admin all-access. 1 service = 1 database = 1 Prisma schema. Scope canonical: docs/spec/MVP-AUTH-FIRST.md.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/entrypoints/api.ts",
    "dev:worker": "tsx watch src/entrypoints/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:api": "node dist/entrypoints/api.js",
    "start:worker": "node dist/entrypoints/worker.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.json",
    "test:unit": "jest --config jest.config.json --testPathPattern='__tests__/.*(?<!\\.integration)\\.test\\.ts'",
    "test:integration": "jest --config jest.config.json --testPathPattern=__tests__/.*\\.integration\\.test\\.ts --runInBand",
    "test:coverage": "jest --config jest.config.json --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "seed": "tsx prisma/seeds/index.ts",
    "seed:super-admin": "tsx prisma/seeds/super-admin.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "axios": "^1.7.7",
    "bull": "^4.16.3",
    "dayjs": "^1.11.13",
    "fastify": "^4.28.1",
    "ioredis": "^5.3.2",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "testcontainers": "^10.13.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  }
}
